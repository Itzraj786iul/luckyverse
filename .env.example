# Optional: shared “Together” plans for both of you (any device).
# Default project URL/key: src/config/supabasePublic.ts (and optional .env.local for overrides).
# 1) Create a free project at https://supabase.com
# 2) SQL Editor → run:
#
# create table public.future_plans (
#   id uuid primary key,
#   title text not null,
#   body text default '',
#   tag text default '',
#   completed boolean not null default false,
#   created_at timestamptz not null default now()
# );
# alter table public.future_plans enable row level security;
# create policy "fp_select" on public.future_plans for select using (true);
# create policy "fp_insert" on public.future_plans for insert with check (true);
# create policy "fp_update" on public.future_plans for update using (true);
# create policy "fp_delete" on public.future_plans for delete using (true);
#
# 3) Database → Replication → enable Realtime for table future_plans
#
# --- Shared gallery (albums + photos, bucket luckyverse-gallery) ---
# create table public.gallery_albums (
#   id uuid primary key default gen_random_uuid(),
#   title text not null,
#   created_at timestamptz not null default now()
# );
# create table public.gallery_photos (
#   id uuid primary key default gen_random_uuid(),
#   album_id uuid not null references public.gallery_albums(id) on delete cascade,
#   storage_path text not null,
#   public_url text not null,
#   caption text default '',
#   created_at timestamptz not null default now()
# );
# create index gallery_photos_album_id_idx on public.gallery_photos(album_id);
# alter table public.gallery_albums enable row level security;
# alter table public.gallery_photos enable row level security;
# create policy "ga_select" on public.gallery_albums for select using (true);
# create policy "ga_insert" on public.gallery_albums for insert with check (true);
# create policy "gp_select" on public.gallery_photos for select using (true);
# create policy "gp_insert" on public.gallery_photos for insert with check (true);
# create policy "gp_delete" on public.gallery_photos for delete using (true);
# -- Storage: create bucket "luckyverse-gallery" (public) in Dashboard, then:
# insert into storage.buckets (id, name, public) values ('luckyverse-gallery', 'luckyverse-gallery', true)
#   on conflict (id) do nothing;
# create policy "g_read" on storage.objects for select using (bucket_id = 'luckyverse-gallery');
# create policy "g_insert" on storage.objects for insert with check (bucket_id = 'luckyverse-gallery');
# create policy "g_delete" on storage.objects for delete using (bucket_id = 'luckyverse-gallery');
# -- Realtime: enable for gallery_albums and gallery_photos (Replication)
#
# --- Space page: shared thoughts (/space) ---
# create table public.space_thoughts (
#   id uuid primary key default gen_random_uuid(),
#   body text not null,
#   created_at timestamptz not null default now()
# );
# alter table public.space_thoughts enable row level security;
# create policy "st_select" on public.space_thoughts for select using (true);
# create policy "st_insert" on public.space_thoughts for insert with check (true);
# -- Realtime: enable for space_thoughts
#
# Optional overrides — defaults are committed in src/config/supabasePublic.ts
# Vite also exposes NEXT_PUBLIC_* (see vite.config envPrefix).

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
